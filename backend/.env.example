# Google Gemini API key — required
GOOGLE_API_KEY=your_google_api_key_here

# Gemini model for Node 3 — answer synthesis (default: gemini-1.5-pro)
GEMINI_MODEL=gemini-1.5-pro

# Gemini model for Node 1 — country name extraction (default: gemini-1.5-flash)
# Flash has a much higher free-tier quota and is sufficient for simple extraction.
GEMINI_MODEL_FAST=gemini-1.5-flash

# CORS allowed origins.
# Use * to allow all origins (default, suitable for local development).
# In production, set to your frontend URL(s), comma-separated.
# Example: CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
CORS_ORIGINS=*
